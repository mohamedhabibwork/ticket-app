{
  "name": "@ticket-app/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "default": "./src/schema/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun run migrate-non-interactive.ts"
  },
  "dependencies": {
    "@ticket-app/env": "workspace:*",
    "bullmq": "^5.73.2",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "ioredis": "^5.10.1",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ticket-app/config": "workspace:*",
    "@types/pg": "catalog:",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}
