{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.2",
    "@ai-sdk/google": "^3.0.1",
    "@hono/node-ws": "^1.3.0",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@ticket-app/api": "workspace:*",
    "@ticket-app/db": "workspace:*",
    "@ticket-app/env": "workspace:*",
    "ai": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "ws": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ticket-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
