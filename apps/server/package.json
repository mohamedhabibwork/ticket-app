{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    "./middleware/audit": "./src/middleware/audit.ts",
    "./middleware/*": "./src/middleware/*.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.2",
    "@ai-sdk/google": "^3.0.1",
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.3.0",
    "@orpc/json-schema": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@socket.io/redis-adapter": "^8.3.0",
    "@ticket-app/api": "workspace:*",
    "@ticket-app/db": "workspace:*",
    "@ticket-app/env": "workspace:*",
    "@ticket-app/queue": "workspace:*",
    "@types/redis": "^4.0.11",
    "ai": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.0",
    "ws": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ticket-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
