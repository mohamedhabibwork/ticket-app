{
  "extends": "@ticket-app/config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ticket-app/api/*": ["../../packages/api/src/*"],
      "@ticket-app/db/*": ["../../packages/db/src/*"],
      "@ticket-app/env/*": ["../../packages/env/src/*"],
      "@ticket-app/queue/*": ["../../packages/queue/src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "references": [
    { "path": "../../packages/api" },
    { "path": "../../packages/db" },
    { "path": "../../packages/env" },
    { "path": "../../packages/queue" }
  ]
}
